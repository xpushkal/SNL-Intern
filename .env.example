# Copy to .env. The service runs fully without a key (deterministic path);
# a key enables the LLM routing/compare enhancement.
GROQ_API_KEY=

# --- optional overrides (see app/config.py for all knobs) ---
# GROQ_MODEL=llama-3.1-8b-instant      # routing/extraction model
# GROQ_COMPARE_MODEL=llama-3.1-8b-instant
# ENABLE_LLM_RERANK=false              # measured: no gain by default
# ENABLE_MMR=false                     # measured: no gain by default
# INCLUDE_PREPACKAGED=false            # keep pre-packaged Job Solutions out of scope
# LLM_TIMEOUT_S=10
# TOTAL_TIMEOUT_S=25
